---
interface Props {
	title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Studio Raphus - Cyber-Pixel Dev Laboratory" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/dodo-236.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Futuristic & Pixel Typography -->
		<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Share+Tech+Mono&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="scanlines"></div>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--color-bg: #0a0a12;
		--color-surface: #121224;
		--color-primary: #00ffcc;     /* Neon Cyan */
		--color-secondary: #ff0055;   /* Cyber Pink */
		--color-matrix: #39ff14;      /* Glitch Green */
		--color-text: #e2e8f0;
		--pixel-border: 4px solid #00ffcc;
		
		font-family: 'Share Tech Mono', monospace;
		background-color: var(--color-bg);
		color: var(--color-text);
		margin: 0;
		padding: 0;
		overflow-x: hidden;
	}

	/* Retro CRT Scanline Effect */
	.scanlines {
		position: fixed;
		inset: 0;
		pointer-events: none;
		background: linear-gradient(
			rgba(18, 16, 16, 0) 50%, 
			rgba(0, 0, 0, 0.25) 50%
		), linear-gradient(
			90deg,
			rgba(255, 0, 0, 0.06),
			rgba(0, 255, 0, 0.02),
			rgba(0, 0, 255, 0.06)
		);
		background-size: 100% 4px, 6px 100%;
		z-index: 999;
	}

	body {
		display: flex;
		justify-content: center;
		min-height: 100vh;
		padding: 3rem 1rem;
		box-sizing: border-box;
	}

	/* Title Typography */
	.pixel-text {
		font-family: 'Press Start 2P', cursive;
		line-height: 1.5;
	}
</style>